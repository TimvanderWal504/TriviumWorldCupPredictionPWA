# ─────────────────────────────────────────────────────────────────────────────
# Trivium World Cup 2026 — environment variable template
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=twc
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=twc

# ── ASP.NET Core ──────────────────────────────────────────────────────────────
# "Production" for the AK12 deployment (link auth, no E2E endpoints, no Swagger).
# "Development" for local dev (enables Swagger + E2E endpoints).
ASPNETCORE_ENVIRONMENT=Staging

# ── Admin User ID ────────────────────────────────────────────────────────────
ADMIN_USER_ID=fe3a4de8-3243-48b8-b68b-528d35dedeed

# Auth provider: "link" (admin-managed magic links) or "entra" (TWC-20, future).
AUTH__PROVIDER=link

# ── Football data API (API-Football v3 — api-sports.io) ──────────────────────
# Obtain a key from https://dashboard.api-football.com/
# Required for live result ingestion (TWC-9); app starts without it but ingestion is disabled.
FOOTBALL__APIKEY=your_key_here

# ── Web Push / VAPID (TWC-18) ────────────────────────────────────────────────
# Generate keys with: npx web-push generate-vapid-keys
# VAPID subject: a mailto: or https: URI identifying you to push services.
PUSH__VAPIDPUBLICKEY=your_vapid_public_key_here
PUSH__VAPIDPRIVATEKEY=your_vapid_private_key_here
PUSH__VAPIDSUBJECT=mailto:your@email.com

# ── Backup (optional offsite) ─────────────────────────────────────────────────
# Nightly backups are written to the twc_postgres_backups Docker volume.
# To also ship them offsite, configure one of the options below and call
# rclone/rsync from a hook in scripts/backup.sh (see docs/BACKUP_AND_RESTORE.md).
#
# Option A: SFTP / NAS
# BACKUP_SFTP_HOST=your.nas.local
# BACKUP_SFTP_USER=backup
# BACKUP_SFTP_PATH=/backups/twc
#
# Option B: rclone remote (S3, B2, OneDrive, etc.)
# BACKUP_RCLONE_REMOTE=myremote:bucket/twc-backups

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Optional for LAN-only demo.  Required for public HTTPS via Cloudflare Tunnel
# (needed for real Entra auth — TWC-20).
# Obtain from the Cloudflare Zero Trust dashboard and keep in a secrets store.
# Leave blank or omit this variable to run without the tunnel (LAN-only mode).
TUNNEL_TOKEN=
