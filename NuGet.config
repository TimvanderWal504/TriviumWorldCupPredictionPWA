<?xml version="1.0" encoding="utf-8"?>
<!--
  Repo-level NuGet configuration.
  Overrides machine-level sources so only nuget.org is used for this project.
  If your organisation has a private feed proxy, add it here with credentials via
  environment variables or dotnet nuget update source.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
