{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "../dist-e2e",
    "paths": {
      "@helpers/*": ["./helpers/*"],
      "@pages/*": ["./pages/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "../dist-e2e"]
}