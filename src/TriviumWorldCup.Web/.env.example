# Branding — override these to deploy for a different tournament.
# VITE_APP_TITLE      : Full name used in <title> and the PWA manifest name field.
# VITE_APP_SHORT_TITLE: Short name used in the PWA manifest short_name field.
# VITE_APP_NAV_LABEL  : Two-line display label for the nav header and login screen.
#                       Use a pipe character (|) to separate the two lines.
VITE_APP_TITLE=Trivium World Cup 2026
VITE_APP_SHORT_TITLE=TWC 2026
VITE_APP_NAV_LABEL=World Cup|2026
